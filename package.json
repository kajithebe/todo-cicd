{
  "name": "todo-cicd",
  "version": "1.0.0",
  "description": "Simple Todo app with CI/CD pipeline",
  "main": "app.js",
  "scripts": {
    "start": "node app.js",
    "test": "jest",
    "eslint": "eslint .",
    "build:frontend": "cd frontend && npm install && npm run build",
    "build": "npm run build:frontend && cp -r frontend/dist ./dist",
    "start:prod": "node app.js"
  },
  "jest": {
    "testEnvironment": "node",
    "testPathIgnorePatterns": [
      "e2e-tests",
      "frontend"
    ]
  },
  "dependencies": {
    "express": "^4.18.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "eslint": "^9.0.0",
    "jest": "^29.0.0",
    "supertest": "^6.3.4"
  }
}
